<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gerenciador.sistema.DadosPessoaisController" prefWidth="1171.0" prefHeight="757.0">
    <top>
        <Label text="Dados Pessoais" style="-fx-font-size: 24px; -fx-font-weight: bold;" padding="20.0" />
    </top>
    <center>
        <HBox spacing="24.0" padding="20.0">
            <VBox spacing="18.0" prefWidth="420.0">
                <Label text="Informações do usuário" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <GridPane hgap="10.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90.0" halignment="RIGHT" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <Label fx:id="labelNome" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label text="Login:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <Label fx:id="labelLogin" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                        <Label text="Salário:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                        <Label fx:id="labelSalario" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                    </children>
                </GridPane>
                <Label text="Contas" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <ListView fx:id="listaContas" VBox.vgrow="ALWAYS" />
            </VBox>
            <VBox spacing="18.0" prefWidth="620.0">
                <Label text="Registrar salário" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
                <Label wrapText="true" text="Se o salário ou renda mensal não estiver definido, registre-o abaixo. A conta será criada automaticamente se não existir." />
                <GridPane hgap="10.0" vgap="12.0">
                    <columnConstraints>
                        <ColumnConstraints minWidth="90.0" halignment="RIGHT" />
                        <ColumnConstraints hgrow="ALWAYS" />
                    </columnConstraints>
                    <children>
                        <Label text="Valor:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                        <TextField fx:id="setaSalario" GridPane.rowIndex="0" GridPane.columnIndex="1" />
                        <Label text="Conta:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                        <TextField fx:id="contaSalario" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                    </children>
                </GridPane>
                <Button mnemonicParsing="false" onAction="#onRegistrarSalario" defaultButton="true" text="Registrar" />
                <Label fx:id="labelErro" textFill="RED" wrapText="true" />
            </VBox>
        </HBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT" padding="20.0">
            <Button mnemonicParsing="false" onAction="#onVoltar" text="Voltar" />
        </HBox>
    </bottom>
</BorderPane>

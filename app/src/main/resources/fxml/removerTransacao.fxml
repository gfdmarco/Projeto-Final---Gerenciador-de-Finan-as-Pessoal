<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="925.0" prefWidth="1155.0" stylesheets="@app.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gerenciador.sistema.RemoverTransacaoController">
    <top>
        <VBox spacing="8.0">
            <padding>
                <Insets bottom="10" left="20" right="20" top="20" />
            </padding>
            <Label styleClass="header-title" text="Remover Transação" />
            <Label styleClass="instruction-text" text="Selecione a transação que deseja remover e use a opção de remoção abrindo o menu de contexto. Para isso, pressione o botão direito do mouse." wrapText="true" />
        </VBox>
    </top>
    <center>
        <VBox spacing="12.0" styleClass="card">
            <BorderPane.margin>
                <Insets bottom="20" left="20" right="20" top="10" />
            </BorderPane.margin>
            <padding>
                <Insets bottom="24" left="24" right="24" top="24" />
            </padding>
            <TableView fx:id="tabelaTransacoes" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colunaNome" prefWidth="120.0" text="Nome" />
                    <TableColumn fx:id="colunaID" prefWidth="90.0" text="ID" />
                    <TableColumn fx:id="colunaValor" prefWidth="110.0" text="Valor" />
                    <TableColumn fx:id="colunaTags" prefWidth="280.0" text="Tags" />
                    <TableColumn fx:id="colunaCategoria" prefWidth="160.0" text="Categoria" />
                    <TableColumn fx:id="colunaData" prefWidth="140.0" text="Data" />
                    <TableColumn fx:id="colunaConta" prefWidth="160.0" text="Conta" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <HBox alignment="CENTER_RIGHT">
            <padding>
                <Insets bottom="20" left="20" right="20" top="10" />
            </padding>
            <Button mnemonicParsing="false" onAction="#onVoltar" styleClass="secondary-button" text="Voltar" />
        </HBox>
    </bottom>
</BorderPane>

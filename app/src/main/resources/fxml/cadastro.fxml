<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gerenciador.sistema.CadastroController" prefWidth="600.0" prefHeight="400.0">
    <top>
        <VBox alignment="CENTER" spacing="10.0" padding="20.0">
            <Label text="Crie seu cadastro" style="-fx-font-size: 24px; -fx-font-weight: bold;" />
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="16.0" padding="20.0">
            <GridPane hgap="10.0" vgap="14.0">
                <children>
                    <Label text="Nome:" GridPane.rowIndex="0" GridPane.columnIndex="0" />
                    <TextField fx:id="campoNome" GridPane.rowIndex="0" GridPane.columnIndex="1" prefWidth="260.0" />
                    <Label text="Login:" GridPane.rowIndex="1" GridPane.columnIndex="0" />
                    <TextField fx:id="campoLogin" GridPane.rowIndex="1" GridPane.columnIndex="1" />
                    <Label text="Senha:" GridPane.rowIndex="2" GridPane.columnIndex="0" />
                    <PasswordField fx:id="campoSenha" GridPane.rowIndex="2" GridPane.columnIndex="1" />
                </children>
            </GridPane>
            <HBox spacing="10.0">
                <Button mnemonicParsing="false" onAction="#onCadastro" defaultButton="true" text="Cadastrar" />
            </HBox>
            <Label fx:id="labelErro" textFill="RED" wrapText="true" textAlignment="CENTER" />
        </VBox>
    </center>
</BorderPane>

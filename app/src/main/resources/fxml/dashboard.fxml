<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>
<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gerenciador.sistema.DashboardController" prefHeight="920.0" prefWidth="1310.0">
    <top>
        <Label text="Dashboard" style="-fx-font-size: 28px; -fx-font-weight: bold;" BorderPane.alignment="CENTER" />
    </top>
    <left>
        <VBox spacing="12.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label fx:id="labelNome" wrapText="true" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
            <Label text="Saldo Geral:" style="-fx-font-size: 16px;" />
            <Label fx:id="labelSaldoGeral" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Button mnemonicParsing="false" onAction="#onSair" text="Sair" />
        </VBox>
    </left>
    <right>
        <VBox spacing="12.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Ações Rápidas" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <Button mnemonicParsing="false" onAction="#onDadosPessoais" text="Dados Pessoais" />
            <Button mnemonicParsing="false" onAction="#onTransacoes" text="Transações" />
            <Button mnemonicParsing="false" onAction="#onCategorias" text="Categorias" />
            <Button mnemonicParsing="false" onAction="#onContas" text="Contas" />
            <Button mnemonicParsing="false" onAction="#onTags" text="Tags" />
            <Button mnemonicParsing="false" onAction="#onFundos" text="Fundos" />
            <Button mnemonicParsing="false" onAction="#onRelatorios" text="Relatórios" />
        </VBox>
    </right>
    <center>
        <VBox spacing="12.0">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <Label text="Contas" style="-fx-font-size: 18px; -fx-font-weight: bold;" />
            <TableView fx:id="tabelaContas" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="colunaNome" prefWidth="200.0" text="Nome" />
                    <TableColumn fx:id="colunaMontante" prefWidth="180.0" text="Montante" />
                    <TableColumn fx:id="colunaID" prefWidth="180.0" text="ID" />
                    <TableColumn fx:id="colunaTransacoes" prefWidth="200.0" text="Transações" />
                </columns>
            </TableView>
        </VBox>
    </center>
    <bottom>
        <Label fx:id="labelErro" textFill="RED" />
            <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
    </bottom>
</BorderPane>

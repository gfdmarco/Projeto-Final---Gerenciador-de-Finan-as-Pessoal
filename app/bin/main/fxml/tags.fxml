<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="783.0" prefWidth="1058.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="gerenciador.sistema.TagsController">
   <children>
      <Label layoutX="40.0" layoutY="22.0" text="Tags">
         <font>
            <Font size="25.0" />
         </font>
      </Label>
      <Label layoutX="124.0" layoutY="268.0" text="Criacão de Tag">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <TextField fx:id="campoNomeCriar" layoutX="99.0" layoutY="347.0" />
      <Label layoutX="157.0" layoutY="314.0" text="Nome" />
      <Label layoutX="672.0" layoutY="117.0" text="Suas Tags">
         <font>
            <Font size="15.0" />
         </font>
      </Label>
      <TableView fx:id="tabelaTags" layoutX="406.0" layoutY="173.0" prefHeight="518.0" prefWidth="598.0">
         <columns>
            <TableColumn fx:id="colunaNome" prefWidth="300.0" text="Nome" />
            <TableColumn fx:id="colunaTransacoes" prefWidth="297.0" text="Transacões Associadas" />
         </columns>
      </TableView>
      <Button layoutX="153.0" layoutY="392.0" mnemonicParsing="false" onAction="#onCriar" text="Criar" />
